{
  "name": "@agent-format/viewer",
  "version": "0.1.0",
  "description": "Standalone web viewer for .agent files.",
  "license": "MIT",
  "author": "Yuya Morita",
  "repository": {
    "type": "git",
    "url": "https://github.com/knorq-ai/agent-format.git",
    "directory": "packages/viewer"
  },
  "type": "module",
  "scripts": {
    "build:validator": "node scripts/build-validator.mjs",
    "predev": "npm run build:validator",
    "prebuild": "npm run build:validator",
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "npm run build:validator && tsc --noEmit"
  },
  "dependencies": {
    "@agent-format/jp-court": "*",
    "@agent-format/renderer": "*",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "ajv": "^8.17.0",
    "ajv-formats": "^3.0.0",
    "typescript": "^5.4.0",
    "vite": "^6.4.2"
  }
}
