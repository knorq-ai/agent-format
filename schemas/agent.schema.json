{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-format.org/schemas/v0.1/agent.schema.json",
  "title": "Agent File",
  "description": "Visual memory of an AI agent — typed sections + agent config + memory.",
  "type": "object",
  "required": ["version", "name", "createdAt", "updatedAt", "config", "sections", "memory"],
  "properties": {
    "$schema": {
      "type": "string",
      "description": "Optional schema URL for editor / validator integration."
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+(\\.\\d+)?(-[A-Za-z0-9.]+)?$",
      "description": "Spec version (semver). v0.1 for this draft."
    },
    "name": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "icon": { "type": "string", "description": "Single emoji preferred." },
    "createdAt": { "type": "string", "format": "date-time" },
    "updatedAt": { "type": "string", "format": "date-time" },
    "config": { "$ref": "#/$defs/AgentConfig" },
    "sections": {
      "type": "array",
      "items": { "$ref": "#/$defs/Section" }
    },
    "memory": { "$ref": "#/$defs/AgentMemory" }
  },
  "patternProperties": {
    "^x-": {}
  },
  "additionalProperties": false,

  "$defs": {
    "AgentConfig": {
      "type": "object",
      "required": ["proactive"],
      "properties": {
        "proactive": { "type": "boolean" },
        "customInstructions": { "type": "string" },
        "reviewRequired": { "type": "boolean" },
        "tasks": {
          "type": "array",
          "items": { "$ref": "#/$defs/AgentTask" }
        }
      },
      "additionalProperties": false
    },

    "AgentTask": {
      "type": "object",
      "required": ["id", "trigger", "prompt"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "trigger": { "enum": ["manual", "daily", "weekly"] },
        "prompt": { "type": "string" },
        "day": {
          "enum": ["monday", "tuesday", "wednesday", "thursday", "friday", "saturday", "sunday"]
        },
        "lastRun": { "type": "string", "format": "date-time" },
        "label": { "type": "string" }
      },
      "additionalProperties": false,
      "allOf": [
        {
          "if": { "properties": { "trigger": { "const": "weekly" } } },
          "then": { "required": ["day"] }
        }
      ]
    },

    "AgentMemory": {
      "type": "object",
      "required": ["observations", "preferences"],
      "properties": {
        "observations": {
          "type": "array",
          "items": { "type": "string" }
        },
        "preferences": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        }
      },
      "additionalProperties": false
    },

    "SectionBase": {
      "type": "object",
      "required": ["id", "type", "label", "order"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "type": {
          "description": "Core section type (enum) or a namespaced extension type `x-<vendor>:<name>` per spec § 7.2.",
          "anyOf": [
            {
              "enum": [
                "kanban", "checklist", "notes", "timeline", "table",
                "log", "metrics", "diagram", "report", "form",
                "links", "references", "family-graph"
              ]
            },
            {
              "type": "string",
              "pattern": "^x-[a-z0-9][a-z0-9-]*:[a-z][a-z0-9-]*$"
            }
          ]
        },
        "label": { "type": "string" },
        "icon": { "type": "string" },
        "order": { "type": "number" }
      }
    },

    "ExtensionSection": {
      "description": "Namespaced extension section type (`x-<vendor>:<name>`). Core schema does not constrain `data`; vendors publish their own schema.",
      "unevaluatedProperties": false,
      "allOf": [
        { "$ref": "#/$defs/SectionBase" },
        {
          "properties": {
            "type": {
              "type": "string",
              "pattern": "^x-[a-z0-9][a-z0-9-]*:[a-z][a-z0-9-]*$"
            },
            "data": {}
          },
          "required": ["data"]
        }
      ]
    },

    "Section": {
      "oneOf": [
        { "$ref": "#/$defs/KanbanSection" },
        { "$ref": "#/$defs/ChecklistSection" },
        { "$ref": "#/$defs/NotesSection" },
        { "$ref": "#/$defs/TimelineSection" },
        { "$ref": "#/$defs/TableSection" },
        { "$ref": "#/$defs/LogSection" },
        { "$ref": "#/$defs/MetricsSection" },
        { "$ref": "#/$defs/DiagramSection" },
        { "$ref": "#/$defs/ReportSection" },
        { "$ref": "#/$defs/FormSection" },
        { "$ref": "#/$defs/LinksSection" },
        { "$ref": "#/$defs/ReferencesSection" },
        { "$ref": "#/$defs/FamilyGraphSection" },
        { "$ref": "#/$defs/ExtensionSection" }
      ]
    },

    "FamilyGraphPerson": {
      "type": "object",
      "required": ["id", "name"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "role": { "type": "string" },
        "birthday": { "type": "string" },
        "address": { "type": "string" },
        "deathDate": { "type": "string" },
        "aliases": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": false
    },

    "FamilyGraphRelationship": {
      "type": "object",
      "required": ["type", "person1Id", "person2Id"],
      "properties": {
        "type": { "enum": ["spouse", "parent-child"] },
        "person1Id": { "type": "string" },
        "person2Id": { "type": "string" },
        "details": { "type": "string" },
        "dissolved": { "type": "boolean" }
      },
      "additionalProperties": false
    },

    "FamilyGraphData": {
      "type": "object",
      "required": ["persons", "relationships"],
      "properties": {
        "variant": { "type": "string" },
        "focusedPersonId": { "type": "string" },
        "persons": {
          "type": "array",
          "items": { "$ref": "#/$defs/FamilyGraphPerson" }
        },
        "relationships": {
          "type": "array",
          "items": { "$ref": "#/$defs/FamilyGraphRelationship" }
        }
      },
      "additionalProperties": false
    },

    "FamilyGraphSection": {
      "unevaluatedProperties": false,
      "allOf": [
        { "$ref": "#/$defs/SectionBase" },
        {
          "properties": {
            "type": { "const": "family-graph" },
            "data": { "$ref": "#/$defs/FamilyGraphData" }
          },
          "required": ["data"]
        }
      ]
    },

    "KanbanSection": {
      "unevaluatedProperties": false,
      "allOf": [
        { "$ref": "#/$defs/SectionBase" },
        {
          "properties": {
            "type": { "const": "kanban" },
            "data": {
              "type": "object",
              "required": ["columns", "items", "labels"],
              "additionalProperties": false,
              "properties": {
                "columns": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "required": ["id", "name", "category", "order"],
                    "additionalProperties": false,
                    "properties": {
                      "id": { "type": "string" },
                      "name": { "type": "string" },
                      "category": { "type": "string" },
                      "wipLimit": { "type": "number" },
                      "order": { "type": "number" },
                      "isCollapsed": { "type": "boolean" }
                    }
                  }
                },
                "items": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "required": ["id", "title", "type", "status", "priority", "labelIds", "blockedBy", "createdAt", "updatedAt"],
                    "additionalProperties": false,
                    "properties": {
                      "id": { "type": "string" },
                      "title": { "type": "string" },
                      "description": { "type": "string" },
                      "type": { "type": "string" },
                      "status": { "type": "string" },
                      "priority": { "type": "string" },
                      "assignee": { "type": "string" },
                      "labelIds": { "type": "array", "items": { "type": "string" } },
                      "blockedBy": { "type": "array", "items": { "type": "string" } },
                      "estimate": { "type": "number" },
                      "startDate": { "type": "string" },
                      "dueDate": { "type": "string" },
                      "milestoneId": { "type": "string" },
                      "cycleId": { "type": "string" },
                      "comments": {
                        "type": "array",
                        "items": {
                          "type": "object",
                          "required": ["id", "author", "text", "createdAt"],
                          "additionalProperties": false,
                          "properties": {
                            "id": { "type": "string" },
                            "author": { "type": "string" },
                            "text": { "type": "string" },
                            "createdAt": { "type": "string", "format": "date-time" }
                          }
                        }
                      },
                      "createdAt": { "type": "string", "format": "date-time" },
                      "updatedAt": { "type": "string", "format": "date-time" }
                    }
                  }
                },
                "labels": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "required": ["id", "name", "color"],
                    "additionalProperties": false,
                    "properties": {
                      "id": { "type": "string" },
                      "name": { "type": "string" },
                      "color": { "type": "string" }
                    }
                  }
                },
                "team": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "required": ["id", "name"],
                    "additionalProperties": false,
                    "properties": {
                      "id": { "type": "string" },
                      "name": { "type": "string" },
                      "role": { "type": "string" }
                    }
                  }
                }
              }
            }
          },
          "required": ["data"]
        }
      ]
    },

    "ChecklistSection": {
      "unevaluatedProperties": false,
      "allOf": [
        { "$ref": "#/$defs/SectionBase" },
        {
          "properties": {
            "type": { "const": "checklist" },
            "data": {
              "type": "object",
              "required": ["groups"],
              "additionalProperties": false,
              "properties": {
                "groups": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "required": ["id", "title", "items"],
                    "additionalProperties": false,
                    "properties": {
                      "id": { "type": "string" },
                      "title": { "type": "string" },
                      "items": {
                        "type": "array",
                        "items": {
                          "type": "object",
                          "required": ["id", "text", "checked"],
                          "additionalProperties": false,
                          "properties": {
                            "id": { "type": "string" },
                            "text": { "type": "string" },
                            "checked": { "type": "boolean" }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "required": ["data"]
        }
      ]
    },

    "NotesSection": {
      "unevaluatedProperties": false,
      "allOf": [
        { "$ref": "#/$defs/SectionBase" },
        {
          "properties": {
            "type": { "const": "notes" },
            "data": {
              "type": "object",
              "required": ["blocks"],
              "additionalProperties": false,
              "properties": {
                "blocks": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "required": ["id", "content"],
                    "additionalProperties": false,
                    "properties": {
                      "id": { "type": "string" },
                      "content": { "type": "string" }
                    }
                  }
                }
              }
            }
          },
          "required": ["data"]
        }
      ]
    },

    "TimelineSection": {
      "unevaluatedProperties": false,
      "allOf": [
        { "$ref": "#/$defs/SectionBase" },
        {
          "properties": {
            "type": { "const": "timeline" },
            "data": {
              "type": "object",
              "required": ["items", "milestones"],
              "additionalProperties": false,
              "properties": {
                "items": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "required": ["id", "title", "status"],
                    "additionalProperties": false,
                    "properties": {
                      "id": { "type": "string" },
                      "title": { "type": "string" },
                      "description": { "type": "string" },
                      "startDate": { "type": "string" },
                      "endDate": { "type": "string" },
                      "status": { "type": "string" },
                      "issueIds": { "type": "array", "items": { "type": "string" } }
                    }
                  }
                },
                "milestones": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "required": ["id", "name", "status"],
                    "additionalProperties": false,
                    "properties": {
                      "id": { "type": "string" },
                      "name": { "type": "string" },
                      "description": { "type": "string" },
                      "targetDate": { "type": "string" },
                      "status": { "type": "string" }
                    }
                  }
                }
              }
            }
          },
          "required": ["data"]
        }
      ]
    },

    "TableSection": {
      "unevaluatedProperties": false,
      "allOf": [
        { "$ref": "#/$defs/SectionBase" },
        {
          "properties": {
            "type": { "const": "table" },
            "data": {
              "type": "object",
              "required": ["columns", "rows"],
              "additionalProperties": false,
              "properties": {
                "columns": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "required": ["key", "label", "type"],
                    "additionalProperties": false,
                    "properties": {
                      "key": { "type": "string" },
                      "label": { "type": "string" },
                      "type": { "enum": ["text", "number", "date", "select", "status"] },
                      "options": { "type": "array", "items": { "type": "string" } }
                    }
                  }
                },
                "rows": {
                  "description": "Row shape is column-driven; keys match `columns[].key`. Renderers tolerate extra keys.",
                  "type": "array",
                  "items": { "type": "object" }
                }
              }
            }
          },
          "required": ["data"]
        }
      ]
    },

    "LogSection": {
      "unevaluatedProperties": false,
      "allOf": [
        { "$ref": "#/$defs/SectionBase" },
        {
          "properties": {
            "type": { "const": "log" },
            "data": {
              "type": "object",
              "required": ["entries"],
              "additionalProperties": false,
              "properties": {
                "entries": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "required": ["id", "type", "title", "status", "createdAt"],
                    "additionalProperties": false,
                    "properties": {
                      "id": { "type": "string" },
                      "type": { "type": "string" },
                      "title": { "type": "string" },
                      "description": { "type": "string" },
                      "severity": { "type": "string" },
                      "status": { "type": "string" },
                      "context": { "type": "string" },
                      "decision": { "type": "string" },
                      "alternatives": { "type": "array", "items": { "type": "string" } },
                      "owner": { "type": "string" },
                      "createdAt": { "type": "string", "format": "date-time" }
                    }
                  }
                }
              }
            }
          },
          "required": ["data"]
        }
      ]
    },

    "MetricsSection": {
      "unevaluatedProperties": false,
      "allOf": [
        { "$ref": "#/$defs/SectionBase" },
        {
          "properties": {
            "type": { "const": "metrics" },
            "data": {
              "type": "object",
              "required": ["cards"],
              "additionalProperties": false,
              "properties": {
                "cards": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "required": ["id", "label", "value"],
                    "additionalProperties": false,
                    "properties": {
                      "id": { "type": "string" },
                      "label": { "type": "string" },
                      "value": { "type": ["string", "number"] },
                      "unit": { "type": "string" },
                      "trend": { "enum": ["up", "down", "flat"] },
                      "color": { "type": "string" }
                    }
                  }
                }
              }
            }
          },
          "required": ["data"]
        }
      ]
    },

    "DiagramNode": {
      "type": "object",
      "required": ["id", "label", "children"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string" },
        "label": { "type": "string" },
        "description": { "type": "string" },
        "children": {
          "type": "array",
          "items": { "$ref": "#/$defs/DiagramNode" }
        }
      }
    },

    "DiagramSection": {
      "unevaluatedProperties": false,
      "allOf": [
        { "$ref": "#/$defs/SectionBase" },
        {
          "properties": {
            "type": { "const": "diagram" },
            "data": {
              "type": "object",
              "required": ["root"],
              "additionalProperties": false,
              "properties": {
                "root": { "$ref": "#/$defs/DiagramNode" }
              }
            }
          },
          "required": ["data"]
        }
      ]
    },

    "ReportSection": {
      "unevaluatedProperties": false,
      "allOf": [
        { "$ref": "#/$defs/SectionBase" },
        {
          "properties": {
            "type": { "const": "report" },
            "data": {
              "type": "object",
              "required": ["template", "reports"],
              "additionalProperties": false,
              "properties": {
                "template": { "type": "string" },
                "reports": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "required": ["id", "title", "content", "createdAt", "updatedAt"],
                    "additionalProperties": false,
                    "properties": {
                      "id": { "type": "string" },
                      "title": { "type": "string" },
                      "content": { "type": "string" },
                      "createdAt": { "type": "string", "format": "date-time" },
                      "updatedAt": { "type": "string", "format": "date-time" }
                    }
                  }
                }
              }
            }
          },
          "required": ["data"]
        }
      ]
    },

    "FormSection": {
      "unevaluatedProperties": false,
      "allOf": [
        { "$ref": "#/$defs/SectionBase" },
        {
          "properties": {
            "type": { "const": "form" },
            "data": {
              "type": "object",
              "required": ["fields", "submissions"],
              "additionalProperties": false,
              "properties": {
                "fields": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "required": ["id", "label", "type"],
                    "additionalProperties": false,
                    "properties": {
                      "id": { "type": "string" },
                      "label": { "type": "string" },
                      "type": { "enum": ["text", "textarea", "select", "date", "number", "email", "url", "checkbox"] },
                      "options": { "type": "array", "items": { "type": "string" } },
                      "required": { "type": "boolean" },
                      "placeholder": { "type": "string" }
                    }
                  }
                },
                "submissions": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "required": ["id", "values", "submittedAt"],
                    "additionalProperties": false,
                    "properties": {
                      "id": { "type": "string" },
                      "values": {
                        "description": "Field-id-keyed values; shape is field-driven.",
                        "type": "object"
                      },
                      "submittedAt": { "type": "string", "format": "date-time" },
                      "submittedBy": { "type": "string" }
                    }
                  }
                }
              }
            }
          },
          "required": ["data"]
        }
      ]
    },

    "LinksSection": {
      "unevaluatedProperties": false,
      "allOf": [
        { "$ref": "#/$defs/SectionBase" },
        {
          "properties": {
            "type": { "const": "links" },
            "data": {
              "type": "object",
              "required": ["items"],
              "additionalProperties": false,
              "properties": {
                "items": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "required": ["id", "title", "url"],
                    "additionalProperties": false,
                    "properties": {
                      "id": { "type": "string" },
                      "title": { "type": "string" },
                      "url": { "type": "string", "format": "uri" },
                      "description": { "type": "string" },
                      "category": { "type": "string" }
                    }
                  }
                }
              }
            }
          },
          "required": ["data"]
        }
      ]
    },

    "ReferencesSection": {
      "unevaluatedProperties": false,
      "allOf": [
        { "$ref": "#/$defs/SectionBase" },
        {
          "properties": {
            "type": { "const": "references" },
            "data": {
              "type": "object",
              "required": ["items"],
              "additionalProperties": false,
              "properties": {
                "items": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "required": ["id", "fileId", "fileName", "filePath"],
                    "additionalProperties": false,
                    "properties": {
                      "id": { "type": "string" },
                      "fileId": { "type": "string" },
                      "fileName": { "type": "string" },
                      "filePath": { "type": "string" },
                      "memo": { "type": "string" }
                    }
                  }
                }
              }
            }
          },
          "required": ["data"]
        }
      ]
    }
  }
}
